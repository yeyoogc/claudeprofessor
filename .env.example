# ── Gemini API (FREE tier — 15 RPM) ──────────────────────────
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Instagram Graph API ───────────────────────────────────────
# 1. Go to developers.facebook.com → My Apps → Create App → Business
# 2. Add "Instagram Graph API" product
# 3. Connect your Instagram Business/Creator account to a Facebook Page
# 4. Generate a long-lived access token (60-day, renewable)
INSTAGRAM_USER_ID=your_instagram_user_id_here
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token_here

# ── imgbb (free image hosting) ────────────────────────────────
# Register at imgbb.com → API → get free key
# Instagram Graph API requires publicly accessible image URLs
IMGBB_API_KEY=your_imgbb_api_key_here

# ── Email notifications ───────────────────────────────────────
# Gmail App Password: myaccount.google.com → Security → App passwords
EMAIL_FROM=your_email@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password
EMAIL_TO=your_email@gmail.com

# ── Schedule ──────────────────────────────────────────────────
# Hour (24h) to post daily — UTC time
POST_HOUR_UTC=12
POST_MINUTE_UTC=0
